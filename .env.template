# ═══════════════════════════════════════════════════════════════
#  🏛️ Conclave — Configuration
# ═══════════════════════════════════════════════════════════════
#
#  Setup:
#    cp .env.template .env
#    # Edit .env with your keys and preferred models
#
#  The script reads from .env file OR from exported env variables.
#  Environment variables always override .env file values.
#
# ═══════════════════════════════════════════════════════════════


# ── Provider Mode ────────────────────────────────────────────
#  "direct"     = separate API key per provider (default)
#  "openrouter" = one API key for all models via OpenRouter
CONCLAVE_PROVIDER_MODE=direct


# ═══════════════════════════════════════════════════════════════
#  API KEYS
# ═══════════════════════════════════════════════════════════════

# ── Option A: OpenRouter (1 key for everything) ─────────────
#  Get your key at https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-...

# ── Option B: Direct API keys (one per provider) ────────────

#  Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

#  Google Gemini — https://aistudio.google.com/apikey
GOOGLE_GEMINI_API_KEY=AIza...

#  OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

#  xAI Grok (optional) — https://console.x.ai/
# XAI_API_KEY=xai-...


# ═══════════════════════════════════════════════════════════════
#  COUNCIL MEMBERS — Models that debate
# ═══════════════════════════════════════════════════════════════
#
#  Format: CONCLAVE_MEMBER_<KEY>_MODEL=<model_id>
#          CONCLAVE_MEMBER_<KEY>_LABEL=<display_name>
#          CONCLAVE_MEMBER_<KEY>_ICON=<emoji>
#          CONCLAVE_MEMBER_<KEY>_OPENROUTER=<openrouter_model_id>
#          CONCLAVE_MEMBER_<KEY>_LOCAL=true  ← skip API, Claude Code handles it
#
#  <KEY> is uppercase. The script auto-discovers all members
#  by scanning for CONCLAVE_MEMBER_*_MODEL variables.
#
#  Direct model IDs → used when CONCLAVE_PROVIDER_MODE=direct
#  OpenRouter model IDs → used when CONCLAVE_PROVIDER_MODE=openrouter
#  LOCAL=true → no API call; Claude Code generates this member's response directly
#

# ── Claude (LOCAL — runs in Claude Code, no API call) ────────
CONCLAVE_MEMBER_CLAUDE_MODEL=claude-opus-4.6
CONCLAVE_MEMBER_CLAUDE_LABEL=Claude
CONCLAVE_MEMBER_CLAUDE_ICON=🟣
CONCLAVE_MEMBER_CLAUDE_PROVIDER=anthropic
CONCLAVE_MEMBER_CLAUDE_LOCAL=true

# ── Gemini ───────────────────────────────────────────────────
CONCLAVE_MEMBER_GEMINI_MODEL=gemini-3.1-pro-preview
CONCLAVE_MEMBER_GEMINI_LABEL=Gemini
CONCLAVE_MEMBER_GEMINI_ICON=🔵
CONCLAVE_MEMBER_GEMINI_PROVIDER=google
CONCLAVE_MEMBER_GEMINI_OPENROUTER=google/gemini-3.1-pro-preview

# ── GPT ──────────────────────────────────────────────────────
CONCLAVE_MEMBER_GPT_MODEL=gpt-5.2
CONCLAVE_MEMBER_GPT_LABEL=GPT
CONCLAVE_MEMBER_GPT_ICON=🟢
CONCLAVE_MEMBER_GPT_PROVIDER=openai
CONCLAVE_MEMBER_GPT_OPENROUTER=openai/gpt-5.2

# ── Grok (uncomment to enable) ──────────────────────────────
# CONCLAVE_MEMBER_GROK_MODEL=grok-4
# CONCLAVE_MEMBER_GROK_LABEL=Grok
# CONCLAVE_MEMBER_GROK_ICON=⚫
# CONCLAVE_MEMBER_GROK_PROVIDER=xai
# CONCLAVE_MEMBER_GROK_OPENROUTER=x-ai/grok-4

# ── Llama (uncomment to enable) ─────────────────────────────
# CONCLAVE_MEMBER_LLAMA_MODEL=llama-4-maverick
# CONCLAVE_MEMBER_LLAMA_LABEL=Llama
# CONCLAVE_MEMBER_LLAMA_ICON=🟠
# CONCLAVE_MEMBER_LLAMA_PROVIDER=meta
# CONCLAVE_MEMBER_LLAMA_OPENROUTER=meta-llama/llama-4-maverick


# ═══════════════════════════════════════════════════════════════
#  CHAIRMAN (Phase 3 synthesis)
# ═══════════════════════════════════════════════════════════════
#  The chairman is Claude Code itself — no extra API call needed.
#  Claude Code reads the JSON from Phase 1 (+ Phase 2 in deep mode)
#  and synthesizes the final answer directly.
#
#  No configuration needed here.


# ═══════════════════════════════════════════════════════════════
#  GENERATION SETTINGS
# ═══════════════════════════════════════════════════════════════
CONCLAVE_TEMPERATURE=0.7
CONCLAVE_MAX_TOKENS=2048
CONCLAVE_TIMEOUT=120

# Retry with exponential backoff for transient API errors (429, 5xx, timeouts)
CONCLAVE_MAX_RETRIES=3
CONCLAVE_RETRY_BASE_DELAY=1.0

# Anonymize responses in Phase 2 cross-critique (true/false)
CONCLAVE_ANONYMIZE=true
